diff --git a/custom/conf/app.example.ini b/custom/conf/app.example.ini
index 40dd7d56db..f6bf1bb293 100644
--- a/custom/conf/app.example.ini
+++ b/custom/conf/app.example.ini
@@ -232,6 +232,13 @@ RUN_USER = ; git
 ;; Command template for authorized keys entries
 ;SSH_AUTHORIZED_KEYS_COMMAND_TEMPLATE = {{.AppPath}} --config={{.CustomConf}} serv key-{{.Key.ID}}
 ;;
+;; Enable ability for users to configure `cert-authority` SSH public keys, which then allows
+;; use of SSH certificates signed by such keys for accessing account resources via SSH.
+;; Certificates can be short-lived, and underlying keys can be ephemeral and do not need to be
+;; registered. Note this is distinct from SSH_TRUSTED_USER_CA_KEYS, which are instance wide:
+;; this settings allows users to manage their own, user-specific CAs.
+;SSH_ENABLE_CERT_AUTH = false
+;;
 ;; Timeout for any write to ssh connections. (Set to -1 to disable all timeouts.)
 ;; Will default to the PER_WRITE_TIMEOUT.
 ;SSH_PER_WRITE_TIMEOUT = 30s
