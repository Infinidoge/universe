+
+package forgejo_migrations
+
+import (
+	"xorm.io/xorm"
+)
+
+func init() {
+	registerMigration(&Migration{
+		Description: "Add new columns (is_ca, principals) to public_key for user-defined SSH CAs",
+		Upgrade:     addSSHCAFieldsToPublicKey,
+	})
